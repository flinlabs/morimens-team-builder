# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

#morisources
/morisources

# Generated DB files — these are recreated by `npm run sync` (the prebuild hook)
# fetching from SKeyDB at build time, so they don't need to be committed.
!/db/.gitkeep

# EXCEPTIONS: these two are NOT produced by the sync (bis.json is editorial/
# derived; gameplay-math.json is a hand-maintained slim copy). They must be
# committed so the build can import them on a clean checkout (e.g. Vercel).
!/db/bis.json
!/db/gameplay-math.json

# Downloaded fan-use art (recreated by `npm run assets`); not committed.
/public/assets